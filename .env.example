# Copy to .env and fill in values.
# Database: use config/database.yml (see config/database.yml.example) or set DATABASE_URL here to override.

# App
APP_NAME=Niyam
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# Database (optional override — otherwise uses config/database.yml)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_development

# JWT
JWT_SECRET_KEY=jwt-secret-change-me-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (caching + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Worker: gevent = one OS process, many greenlets (default 1000). Use prefork + low concurrency if you prefer processes.
# CELERY_WORKER_POOL=gevent
# CELERY_WORKER_CONCURRENCY=1000

# E-sign: optional folder for HTML snapshots of merged documents ({dir}/{account_id}/{request_id}.html)
# ESIGN_ARTIFACTS_DIR=/tmp/forge-esign-artifacts
# Signed packages (PDF via WeasyPrint + drawn signature). Default: ./storage/esign_signed/
# ESIGN_SIGNED_DOCUMENTS_DIR=/var/lib/forge/esign_signed
# Job attachments root directory. Default: ./storage/job_attachments/
# JOB_ATTACHMENTS_DIR=/var/lib/forge/job_attachments

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Candidate portal (/candidate-portal): required for register/login — your tenant accounts.id (0 = disabled)
CANDIDATE_PORTAL_ACCOUNT_ID=1

# Frontend (SPA origin — OAuth redirects after Gmail connect; e-sign public links if used)
FRONTEND_PUBLIC_URL=http://localhost:5173

# Communication channels — Gmail OAuth (Settings → Communication channels → Email)
# Create OAuth 2.0 credentials in Google Cloud Console; add the redirect URI exactly as below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/communication_channels/oauth/google/callback
